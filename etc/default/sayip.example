# Configuration for sayip-node-utils
# Copy to /etc/default/sayip or let the package install this file on first install.

# Asterisk sound directory for digits and letters (locale-specific).
ASTSND=/usr/share/asterisk/sounds/en

# Directory containing package prompt files (ip-address, halt, reboot, etc.).
CUSTOM_SOUNDS=/usr/local/share/asterisk/sounds

# Extra seconds added after calculated ulaw playback duration.
PLAYBACK_PADDING=0.5

# Fixed delay after intro prompts; 0 means derive duration from the audio file size.
SLEEP_AFTER_INTRO=0

# Comma-separated interface name prefixes to skip when announcing local IPs.
SKIP_IF_PREFIX=docker,veth,br-

# Local IP announcement mode (used when no interface override is set):
#   default_route - announce the IPv4 on the kernel default-route interface
#   all           - announce every non-skipped interface address
LOCAL_IP_MODE=default_route

# Announce only this interface (overrides LOCAL_IP_MODE and PREFER_INTERFACES).
# Use when the node is reached via VPN but default route is still wlan0, e.g.:
# LOCAL_IP_INTERFACE=wrinkles
LOCAL_IP_INTERFACE=

# Try these interfaces in order before LOCAL_IP_MODE fallback.
# Example when VPN is how you reach the node but wlan0 holds the default route:
# PREFER_INTERFACES=wrinkles,wg0
PREFER_INTERFACES=

# User-Agent header for public IP HTTP lookups.
USER_AGENT=sayip-node-utils/1.0
