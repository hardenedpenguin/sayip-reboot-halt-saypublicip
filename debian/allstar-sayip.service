[Unit]
Description=AllStar SayIP Service - Announce Local IP on Boot
After=network-online.target asterisk.service
Wants=network-online.target
Requires=asterisk.service

[Service]
Type=oneshot
ExecStart=/usr/sbin/sayip-node-utils local NODE_NUMBER_PLACEHOLDER
RemainAfterExit=yes
User=asterisk
Group=asterisk

[Install]
WantedBy=multi-user.target

