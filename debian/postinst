#!/bin/sh
set -e

# Postinst script - run after package installation

is_valid_node_number() {
    echo "$1" | grep -qE '^[0-9]{1,10}$'
}

get_node_number() {
    if [ -n "$NODE_NUMBER" ]; then
        echo "$NODE_NUMBER"
        return 0
    fi

    if [ -f /usr/share/debconf/confmodule ]; then
        . /usr/share/debconf/confmodule 2>/dev/null || true
        if db_get sayip-node-utils/node-number 2>/dev/null && [ -n "$RET" ]; then
            echo "$RET"
            return 0
        fi
    fi

    if [ -t 0 ] && [ -t 1 ]; then
        echo ""
        echo "AllStarLink Node Number Configuration"
        echo "======================================"
        printf "Please enter your AllStarLink node number: "
        read -r entered
        echo "$entered"
        return 0
    fi

    return 1
}

install_sayip_conf() {
    node_number="$1"
    example="/usr/share/doc/sayip-node-utils/sayip.conf.example"
    target="/etc/asterisk/custom/rpt/sayip.conf"

    mkdir -p /etc/asterisk/custom/rpt

    if [ -n "$node_number" ]; then
        sed "s/\$NODE/$node_number/g" "$example" > "$target"
    else
        cp "$example" "$target"
    fi

    chmod 0644 "$target"
    chown asterisk:asterisk "$target" 2>/dev/null || true
}

install_systemd_service() {
    node_number="$1"
    example="/usr/share/doc/sayip-node-utils/examples/allstar-sayip.service"
    target="/etc/systemd/system/allstar-sayip.service"

    [ -n "$node_number" ] || return 0
    [ -f "$example" ] || return 0

    sed "s/NODE_NUMBER_PLACEHOLDER/$node_number/g" "$example" > "$target"
    chmod 0644 "$target"
    systemctl daemon-reload 2>/dev/null || true
    systemctl enable allstar-sayip.service 2>/dev/null || true
}

if [ "$1" = "configure" ]; then
    node_number=""
    if node_number="$(get_node_number)"; then
        if ! is_valid_node_number "$node_number"; then
            echo "Warning: Invalid node number format: $node_number (expected 1-10 digits)"
            node_number=""
        fi
    fi

    if [ ! -f /etc/default/sayip ] && [ -f /usr/share/doc/sayip-node-utils/sayip.example ]; then
        cp /usr/share/doc/sayip-node-utils/sayip.example /etc/default/sayip
        chmod 0644 /etc/default/sayip
        echo "Default configuration installed at /etc/default/sayip"
    fi

    if [ -f /etc/sudoers.d/sayip-node-utils ]; then
        chmod 0440 /etc/sudoers.d/sayip-node-utils
        if command -v visudo >/dev/null 2>&1; then
            visudo -cf /etc/sudoers.d/sayip-node-utils >/dev/null 2>&1 || {
                echo "Warning: sudoers entry failed validation; halt/reboot may require root"
            }
        fi
    fi

    if [ -f /etc/asterisk/custom/rpt/sayip.conf ] && [ -n "$node_number" ]; then
        install_sayip_conf "$node_number"
        echo "Configuration file updated at /etc/asterisk/custom/rpt/sayip.conf"
    elif [ ! -f /etc/asterisk/custom/rpt/sayip.conf ]; then
        install_sayip_conf "$node_number"
        echo "Configuration file created at /etc/asterisk/custom/rpt/sayip.conf"
    else
        echo "Configuration file /etc/asterisk/custom/rpt/sayip.conf already exists, skipping..."
    fi

    chown asterisk:asterisk /usr/sbin/sayip-node-utils 2>/dev/null || true
    chown -R asterisk:asterisk /usr/local/share/asterisk/sounds 2>/dev/null || true

    if [ -n "$node_number" ]; then
        install_systemd_service "$node_number"
        echo "Systemd service allstar-sayip.service installed and enabled"
    elif [ ! -f /etc/systemd/system/allstar-sayip.service ]; then
        echo "No node number configured; boot-time IP announcement service was not created."
        echo "Reinstall with NODE_NUMBER=12345 or configure debconf to enable it."
    fi
fi

exit 0
